{
    "expo": {
        "name": "Correcta",
        "slug": "correcta",
        "version": "0.1.0",
        "orientation": "portrait",
        "icon": "./src/assets/icon.png",
        "scheme": "correcta",
        "userInterfaceStyle": "automatic",
        "runtimeVersion": {
            "policy": "appVersion"
        },
        "updates": {
            "fallbackToCacheTimeout": 0
        },
        "assetBundlePatterns": ["**/*"],
        "plugins": [
            "expo-dev-client",
            "expo-updates",
            [
                "expo-build-properties",
                {
                    "android": {
                        "minSdkVersion": 26,
                        "useDayNightTheme": true
                    }
                }
            ],
            [
                "expo-notifications",
                {
                    "color": "#24478F",
                    "defaultChannel": "correcta-reminders"
                }
            ],
            "react-native-nitro-fetch",
            "react-native-bottom-tabs"
        ],
        "ios": {
            "bundleIdentifier": "com.luisgarcia.correcta",
            "deploymentTarget": "16.4",
            "supportsTablet": true
        },
        "android": {
            "package": "com.luisgarcia.correcta",
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./src/assets/android-icon-foreground.png",
                "backgroundImage": "./src/assets/android-icon-background.png",
                "monochromeImage": "./src/assets/android-icon-monochrome.png"
            },
            "predictiveBackGestureEnabled": false
        }
    }
}
