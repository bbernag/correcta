{
    "name": "conecta",
    "version": "0.1.0",
    "private": true,
    "main": "index.ts",
    "scripts": {
        "start": "expo start --dev-client",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "prebuild": "expo prebuild",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
        "format": "prettier --write --ignore-unknown .",
        "format:check": "prettier --check --ignore-unknown ."
    },
    "expo": {
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "@bernagl/react-native-date",
                    "expo-modules-jsi",
                    "react-native-nitro-fetch"
                ]
            }
        }
    },
    "dependencies": {
        "@bernagl/react-native-date": "^3.0.0",
        "@bottom-tabs/react-navigation": "^1.3.0",
        "@react-navigation/native": "^7.3.3",
        "@react-navigation/native-stack": "^7.17.5",
        "expo": "~56.0.12",
        "expo-build-properties": "~56.0.19",
        "expo-dev-client": "~56.0.20",
        "expo-status-bar": "~56.0.4",
        "expo-updates": "~56.0.19",
        "react": "19.2.3",
        "react-native": "0.85.3",
        "react-native-bottom-tabs": "^1.3.0",
        "react-native-gesture-handler": "~2.31.1",
        "react-native-keyboard-controller": "^1.21.6",
        "react-native-mmkv": "^4.3.1",
        "react-native-nitro-fetch": "^1.4.1",
        "react-native-nitro-modules": "^0.35.9",
        "react-native-reanimated": "^4.3.1",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "^4.25.2",
        "react-native-unistyles": "^3.2.5",
        "react-native-worklets": "^0.8.3"
    },
    "devDependencies": {
        "@types/react": "~19.2.2",
        "eslint": "^9.39.1",
        "eslint-config-expo": "~56.0.4",
        "prettier": "^3.7.4",
        "typescript": "~6.0.3"
    }
}
